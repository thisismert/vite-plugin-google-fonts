{
  "name": "vite-plugin-google-fonts",
  "version": "1.0.0",
  "description": "A simple Vite plugin for optimizing and self-hosting fonts from Google Fonts.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}

{
  "name": "vite-plugin-google-fonts",
  "version": "2.0.0",
  "description": "A simple Vite plugin for optimizing and self-hosting fonts from Google Fonts.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate:catalog": "node scripts/generate-font-catalog.mjs",
    "prepublishOnly": "npm run generate:catalog && npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thisismert/vite-plugin-google-fonts"
  },
  "homepage": "https://github.com/thisismert/vite-plugin-google-fonts",
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}